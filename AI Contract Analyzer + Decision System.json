      "parameters": {
        "promptType": "define",
        "text": "=Analyze this contract and extract risks:\n\n{{$json.text}}",
        "options": {
          "systemMessage": "You are a contract risk analysis expert.\n\nYou MUST analyze the contract and return:\n- risk score between 0–20\n- priority (HIGH if score >= 10 else NORMAL)\n- structured JSON output only\n\nHigh risk = 15–20\nMedium risk = 5–14\nLow risk = 0–4"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
