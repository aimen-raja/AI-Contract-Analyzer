    {
      "parameters": {
        "jsCode": "let raw = $json.output;\nif (typeof raw === \"string\") {\n  raw = raw.replace(/```json|```/g, '').trim();\n}\n\nlet data;\ntry {\n  data = typeof raw === \"string\" ? JSON.parse(raw) : raw;\n} catch (e) {\n  data = $json;\n}\n\nconst risks = data.risks || [];\n\nconst high = risks.filter(r => r.severity === 'High');\nconst medium = risks.filter(r => r.severity === 'Medium');\nconst low = risks.filter(r => r.severity === 'Low');\n\nfunction formatRisks(arr) {\n  if (!arr.length) return \"None identified\";\n  return arr.map(r => `• *${r.clause}*: ${r.description}`).join(\"\\n\");\n}\nreturn [{\n  json: {\n    score: data.risk_score || 0,\n    priority: data.priority || \"NORMAL\",\n    summary: `This contract has ${risks.length} risks identified.`,\n    high_risks_text: formatRisks(high),\n    medium_risks_text: formatRisks(medium),\n    low_risks_text: formatRisks(low)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
